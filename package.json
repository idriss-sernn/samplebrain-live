{
  "name": "samplebrain",
  "private": true,
  "version": "1.1.4",
  "type": "module",
  "main": "dist/extension.js",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && tsx build.ts --production",
    "build:dev": "npm run typecheck && tsx build.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "start": "npm run build:dev && extensions-cli run",
    "package": "npm run build && extensions-cli package . -i dist/runtime.cjs"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "file:./vendor/ableton-extensions-sdk-1.0.0-beta.0.tgz"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:./vendor/ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@types/node": "^22.0.0",
    "esbuild": "0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
